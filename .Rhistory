hidden = c(512, 256),           # Short + wide
tag    = "short_wide"
)
)
mlp_rdm <- nn_module(
"mlp_rdm",
initialize = function(input_dim,
hidden = c(256, 128, 64, 32),
dropout = 0.10) {
layers <- list()
in_dim <- input_dim
for (h in hidden) {
layers <- append(layers, list(
nn_linear(in_dim, h),
nn_relu(),
nn_dropout(p = dropout)
))
in_dim <- h
}
self$trunk <- nn_sequential(!!!layers)
self$head  <- nn_linear(in_dim, 1)  # (ll)
},
forward = function(x) {
self$head(self$trunk(x))
}
)
luz_metric_r2 <- luz_metric(
name   = "r2",
abbrev = "R2",
initialize = function() {
self$ss_res <- 0
self$sum_y  <- 0
self$sum_y2 <- 0
self$n      <- 0
},
update = function(preds, target) {
yhat <- as.numeric(torch::as_array(preds))
y    <- as.numeric(torch::as_array(target))
self$ss_res <- self$ss_res + sum((y - yhat)^2)
self$sum_y  <- self$sum_y  + sum(y)
self$sum_y2 <- self$sum_y2 + sum(y^2)
self$n      <- self$n + length(y)
},
compute = function() {
ss_tot <- self$sum_y2 - (self$sum_y^2 / max(self$n, 1))
if (ss_tot <= 0) return(0)
1 - (self$ss_res / ss_tot)
}
)
cleanup_checkpoints <- luz_callback(
name = "cleanup_checkpoints",
initialize = function(path = "cpt_mlp_rdm", pattern = NULL, remove_dir = TRUE) {
self$path <- path
self$pattern <- pattern
self$remove_dir <- remove_dir
},
on_fit_end = function() {
if (!dir.exists(self$path)) return(invisible(NULL))
files <- list.files(self$path, full.names = TRUE)
if (!is.null(self$pattern)) {
files <- files[grepl(self$pattern, basename(files))]
}
if (length(files)) unlink(files, force = TRUE)
if (self$remove_dir && length(list.files(self$path)) == 0) {
unlink(self$path, recursive = TRUE, force = TRUE)
}
invisible(NULL)
}
)
# Choose one architecture (e.g., long + narrow) for LR search
example_hidden   <- arch_configs[[1]]$hidden
input_dim_base   <- ncol(data_base$X)
fitted_lr <- mlp_rdm %>%
setup(
loss = nn_mse_loss(),
optimizer = optim_adam,
metrics = list(luz_metric_mae(), luz_metric_rmse(), luz_metric_r2())
) %>%
set_hparams(
input_dim = input_dim_base,
hidden    = example_hidden,
dropout   = 0.10
) %>%
set_opt_hparams(lr = 1e-3, weight_decay = 1e-5)
records <- lr_finder(
object = fitted_lr,
data   = data_base$ds_train,
verbose = FALSE,
dataloader_options = list(batch_size = 200),
start_lr = 1e-10,
end_lr   = 1
)
plot(records) +
coord_cartesian(ylim = c(NA, 50)) +
theme_classic()
# Choose LR
chosen_lr <- 1e-3
dir.create(file.path("logs", "rdm"),    recursive = TRUE, showWarnings = FALSE)
dir.create(file.path("trained", "rdm"), recursive = TRUE, showWarnings = FALSE)
epochs <- 30
train_one_arch_variant <- function(arch_cfg, var_cfg) {
arch_name   <- arch_cfg$name
arch_tag    <- arch_cfg$tag
suffix      <- var_cfg$name_suffix
var_tag     <- var_cfg$tag
message("\n=== Training: ", arch_name, suffix,
" (", arch_tag, ", ", var_tag, ") ===")
# rebuild data inside worker
d <- build_rdm_data(var_cfg$all_datasets, batch_size = 200, seed = 101)
input_dim <- ncol(d$X)
dl_train  <- d$dl_train
dl_valid  <- d$dl_valid
# Checkpoint root dir
ckpt_root <- "cpt_mlp_rdm"
dir.create(ckpt_root, recursive = TRUE, showWarnings = FALSE)
# File *path* for this model’s checkpoints
ckpt_path <- file.path(
ckpt_root,
paste0("mlp_rdm_", arch_name, suffix, "_epoch{epoch}.pt")
)
log_file <- file.path(
"logs", "rdm",
paste0("logs_mlp_rdm_", arch_name, suffix, ".csv")
)
fitted <- mlp_rdm %>%
setup(
loss = nn_mse_loss(),
optimizer = optim_adam,
metrics = list(luz_metric_mae(), luz_metric_rmse(), luz_metric_r2())
) %>%
set_hparams(
input_dim = input_dim,
hidden    = arch_cfg$hidden,
dropout   = 0.10
) %>%
set_opt_hparams(lr = chosen_lr, weight_decay = 1e-5) %>%
luz::fit(
dl_train,
epochs     = epochs,
valid_data = dl_valid,
callbacks = list(
luz_callback_keep_best_model(monitor = "valid_loss", mode = "min"),
luz_callback_early_stopping(
monitor  = "valid_loss",
mode     = "min",
patience = 2
),
luz_callback_lr_scheduler(
lr_one_cycle,
max_lr          = 1e-2,
epochs          = epochs,
steps_per_epoch = length(dl_train),
call_on         = "on_batch_end"
),
# Use *file* path, not dir
luz_callback_model_checkpoint(path = ckpt_path),
luz_callback_csv_logger(log_file),
# cleanup root dir, only .pt files
cleanup_checkpoints(path = ckpt_root, pattern = "\\.pt$")
),
verbose = TRUE
)
model_path <- file.path(
"trained", "rdm",
paste0("mlp_rdm_", arch_name, suffix, ".pt")
)
luz_save(fitted, model_path)
invisible(fitted)
}

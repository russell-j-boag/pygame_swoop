list.files("exports/rdm")
list.files("exports/rdm/mlp_rdm_256_128_64_32")
# Select object to load
modpath <- file.path("exports", "rdm", "mlp_rdm_256_128_64_32", "mlp_rdm_256_128_64_32.onnx")
# Import ONNX model
onnx_mod <- onnxruntime$InferenceSession(modpath)
in_name <- onnx_mod$get_inputs()[[1]]$name
# Convert to numpy float32
x_np <- r_to_py(X)$astype("float32")
# Build python dict of input features to feed to ONNX model
feed <- dict()
feed[[in_name]] <- x_np
# Get predicted likelihood
pred <- onnx_mod$run(NULL, feed)[[1]]
# Examine performance
plot(pred,Y)
abline(a=0,b=1,col="red")
cor(pred,Y)

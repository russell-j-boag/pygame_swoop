library(EMC2)
library("dplyr")
# Only one stimulus as correctness arbitrary and S reset to whichever accumulator
# has a higher rate in simulate_one_dataset
designRDM <- design(
model = RDM,
factors = list(subjects = 1, S = 1:2),
Rlevels = 1:2, constants=c(s_lR2=log(1)),
formula = list(v ~ 0+lR, B ~ 0+lR, t0 ~ 0+lR, A ~ 0+lR, s ~ 0+lR),
)
# Only one stimulus as correctness arbitrary and S reset to whichever accumulator
# has a higher rate in simulate_one_dataset
designRDM <- design(
model = RDM,
factors = list(subjects = 1, S = 1:2),
Rlevels = 1:2,
formula = list(v ~ 0+lR, B ~ 0+lR, t0 ~ 0+lR, A ~ 0+lR, s ~ 0+lR),
)
seed <- 101
N <- 100
all_datasets <- simulate_many_datasets(N, designRDM, n_trials = 100, seed = seed,show_progress = F)
all_datasets <- all_datasets %>%
mutate(
S = if_else(as.character(S) == "2", 1L, 0L, missing = NA_integer_),
R = if_else(as.character(R) == "2", 1L, 0L, missing = NA_integer_),
C = as.integer(C)
)
all_datasets
# R, rt, parameter names
X <- as.matrix(select(all_datasets, -c("S", "C", "ll", "dataset_id")))
# Learning target: analytic log-likelihoods
Y <- as.matrix(all_datasets$ll)
# Make sure no reticulate/Python torch has been imported yet
# NB: Usually must restart R if this has been run before in current session
cfg <- setup_onnx_env(env_name = "r-onnx-lite", py_ver = "3.10")  # sets/uses an env that has ONNX but not python torch
onnxruntime <- import("onnxruntime")
